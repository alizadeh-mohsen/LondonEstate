@page
@model LondonEstate.Pages.Admin.Greetings.IndexModel
@{
    ViewData["Title"] = "Greetings";
}

<div class="container-fluid py-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h1 class="h3">Guest Greetings</h1>
    </div>

    @if (!string.IsNullOrEmpty(Model.SuccessMessage))
    {
        <div class="alert alert-success alert-dismissible fade show" role="alert">
            @Model.SuccessMessage
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }

    @if (!string.IsNullOrEmpty(Model.ErrorMessage))
    {
        <div class="alert alert-danger alert-dismissible fade show" role="alert">
            @Model.ErrorMessage
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }

    <!-- Import Section -->
    <div class="card mb-4">
        <div class="card-header">
            <h5 class="mb-0">Import Greetings</h5>
        </div>
        <div class="card-body">
            <form method="post" asp-page-handler="Upload" enctype="multipart/form-data">
                <div class="row g-3">
                    <div class="col-md-8">
                        <div class="input-group">
                            <input type="file" class="form-control" id="excelFile" name="excelFile"
                                   accept=".xlsx,.xls" required />
                            <button class="btn btn-primary" type="submit">
                                <i class="bi bi-cloud-upload me-2"></i>Import Greetings
                            </button>
                        </div>
                    </div>
                </div>
                <small class="text-muted d-block mt-2">
                    Required columns: Property Name (A), Location (B), Booker Name (C), Arrival (D),
                    Departure (E), Reservation No (G), Phone (H)
                </small>
            </form>
        </div>
    </div>

    <!-- Greetings Grid -->
    @if (Model.Greetings.Any())
    {
        <div class="card mb-4">
            <div class="card-header">
                <h5 class="mb-0">Imported Greetings (@Model.Greetings.Count)</h5>
            </div>
            <div class="card-body p-0">
                <div class="table-responsive">
                    <table class="table table-hover mb-0">
                        <thead class="table-light">
                            <tr>
                               
                                <th>Message</th>
                                <th>Phone</th>
                                <th>Action</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var greeting in Model.Greetings)
                            {
                                <tr>
                                    <td>@greeting.WhatsAppMessage</td>
                                    <td>@greeting.Phone</td>
                                    <td>
                                        <button type="button" class="btn btn-sm btn-success send-whatsapp"
                                                data-message="@greeting.WhatsAppMessage"
                                                data-phone="@greeting.Phone">
                                            <i class="bi bi-whatsapp me-1"></i>Send
                                        </button>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    }

    <!-- Custom Message Generator -->
    <div class="card">
        <div class="card-header">
            <h5 class="mb-0">Generate Custom Message</h5>
        </div>
        <div class="card-body">
            <form id="messageGeneratorForm" onsubmit="return false;">
                <!-- Parse from Template Section -->
                <div class="alert alert-info mb-4">
                    <strong>Option 1:</strong> Paste your Booking.com template below to auto-extract details
                </div>
                <div class="mb-3">
                    <label for="bookingTemplate" class="form-label">Paste Booking Template</label>
                    <textarea class="form-control" id="bookingTemplate" rows="8" placeholder="Paste your booking details here..."></textarea>
                    <button type="button" class="btn btn-secondary mt-2" onclick="parseTemplate()">
                        <i class="bi bi-magic me-2"></i>Extract Details
                    </button>
                </div>

                <hr />

                <div class="alert alert-info mb-4">
                    <strong>Option 2:</strong> Or manually fill in the details below
                </div>

                <div class="row g-3 mb-3">
                    <div class="col-md-6">
                        <label for="checkInDate" class="form-label">Check-in Date</label>
                        <input type="date" class="form-control" id="checkInDate" required />
                    </div>
                    <div class="col-md-6">
                        <label for="checkOutDate" class="form-label">Check-out Date</label>
                        <input type="date" class="form-control" id="checkOutDate" required />
                    </div>
                </div>

                <div class="row g-3 mb-3">
                    <div class="col-md-6">
                        <label for="bookingNumber" class="form-label">Booking Number</label>
                        <input type="text" class="form-control" id="bookingNumber" required />
                    </div>
                    <div class="col-md-6">
                        <label for="propertyName" class="form-label">Property Name</label>
                        <input type="text" class="form-control" id="propertyName"  required />
                    </div>
                </div>

                <div class="row g-3 mb-3">
                    <div class="col-md-6">
                        <label for="guestName" class="form-label">Guest Name</label>
                        <input type="text" class="form-control" id="guestName"  required />
                    </div>
                    <div class="col-md-6">
                        <label for="phoneNumber" class="form-label">Phone Number</label>
                        <input type="tel" class="form-control" id="phoneNumber"  required />
                    </div>
                </div>

                <button type="button" class="btn btn-primary mb-3" onclick="generateMessage()">
                    <i class="bi bi-file-text me-2"></i>Generate Message
                </button>

                <div class="mb-3">
                    <label for="generatedMessage" class="form-label">Generated Message</label>
                    <textarea class="form-control" id="generatedMessage" rows="10" readonly></textarea>
                </div>

                <button type="button" class="btn btn-success" onclick="copyToClipboard()">
                    <i class="bi bi-clipboard me-2"></i>Copy to Clipboard
                </button>
                <button type="button" class="btn btn-info" onclick="openWhatsApp()">
                    <i class="bi bi-whatsapp me-2"></i>Send on WhatsApp
                </button>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        // Format date to "dd MMM yyyy" format
        function formatDate(dateString) {
            const options = { day: '2-digit', month: 'short', year: 'numeric' };
            return new Date(dateString + 'T00:00:00').toLocaleDateString('en-GB', options);
        }

        // Parse template and extract booking details
        function parseTemplate() {
            const template = document.getElementById('bookingTemplate').value;

            if (!template) {
                alert('Please paste the booking template first.');
                return;
            }

            // Extract Check-in date (format: "Day DD Mon YYYY")
            const checkInMatch = template.match(/Check-in\s*\n\s*([A-Za-z]{3})\s+(\d{1,2})\s+([A-Za-z]{3})\s+(\d{4})/);
            
            // Extract Check-out date
            const checkOutMatch = template.match(/Check-out\s*\n\s*([A-Za-z]{3})\s+(\d{1,2})\s+([A-Za-z]{3})\s+(\d{4})/);
            
            // Extract Guest name (before "Genius" or email)
            const guestMatch = template.match(/Guest name:\s*\n\s*([^\n]+?)\s*(?:Genius|cz|\n)/);
            
            // Extract Phone number
            const phoneMatch = template.match(/\+\d[\d\s\-()]{7,}/);
            
            // Extract Booking number
            const bookingMatch = template.match(/Booking number:\s*\n\s*(\d+)/);
            
            // Extract Property Name (not in this template, so leave empty for manual entry)

            if (!checkInMatch || !checkOutMatch || !guestMatch || !phoneMatch || !bookingMatch) {
                alert('Could not extract all required information. Please check the template format.');
                return;
            }

            // Convert date strings to YYYY-MM-DD format
            const months = { 'Jan': '01', 'Feb': '02', 'Mar': '03', 'Apr': '04', 'May': '05', 'Jun': '06',
                           'Jul': '07', 'Aug': '08', 'Sep': '09', 'Oct': '10', 'Nov': '11', 'Dec': '12' };
            
            const checkInDate = `${checkInMatch[4]}-${months[checkInMatch[3]]}-${String(checkInMatch[2]).padStart(2, '0')}`;
            const checkOutDate = `${checkOutMatch[4]}-${months[checkOutMatch[3]]}-${String(checkOutMatch[2]).padStart(2, '0')}`;
            const guestName = guestMatch[1].trim();
            const phoneNumber = phoneMatch[0].trim();
            const bookingNumber = bookingMatch[1];

            // Populate form fields
            document.getElementById('checkInDate').value = checkInDate;
            document.getElementById('checkOutDate').value = checkOutDate;
            document.getElementById('guestName').value = guestName;
            document.getElementById('phoneNumber').value = phoneNumber;
            document.getElementById('bookingNumber').value = bookingNumber;

            // Scroll to property name field for manual entry
            document.getElementById('propertyName').focus();
            // alert(`Extracted: Guest - ${guestName}, Phone - ${phoneNumber}, Booking - ${bookingNumber}\n\nPlease enter the Property Name manually.`);
        }

        function generateMessage() {
            const checkInDate = document.getElementById('checkInDate').value;
            const checkOutDate = document.getElementById('checkOutDate').value;
            const bookingNumber = document.getElementById('bookingNumber').value;
            const propertyName = document.getElementById('propertyName').value;
            const guestName = document.getElementById('guestName').value;

            if (!checkInDate || !checkOutDate || !bookingNumber || !propertyName || !guestName) {
                alert('Please fill in all fields.');
                return;
            }

            const formattedCheckIn = formatDate(checkInDate);
            const formattedCheckOut = formatDate(checkOutDate);
            const firstName = guestName.split(' ')[0];

            const message = `Booking.com Reservation No: ${bookingNumber} - (${formattedCheckIn} - ${formattedCheckOut}) - ${propertyName}
Greater London, United Kingdom

Hi ${firstName}, I am Nima, your host for booking in London.

*Check-in at 3 PM*
*Luggage drop off after 11 AM*

I'll send you the check-in instruction tomorrow. Could you please share your estimated arrival time?`;

            document.getElementById('generatedMessage').value = message;
        }

        function copyToClipboard() {
            const message = document.getElementById('generatedMessage').value;
            if (!message) {
                alert('Please generate a message first.');
                return;
            }

            navigator.clipboard.writeText(message).then(() => {
                const button = document.querySelector('button[onclick="copyToClipboard()"]');
                const originalText = button.innerHTML;
                button.innerHTML = '<i class="bi bi-check me-2"></i>Copied!';
                setTimeout(() => {
                    button.innerHTML = originalText;
                }, 2000);
            }).catch(() => {
                alert('Failed to copy message. Please try again.');
            });
        }

        function openWhatsApp() {
            const message = document.getElementById('generatedMessage').value;
            const phoneNumber = document.getElementById('phoneNumber').value;

            if (!message) {
                alert('Please generate a message first.');
                return;
            }

            if (!phoneNumber) {
                alert('Please enter a phone number.');
                return;
            }

            // Clean phone number - remove spaces, dashes, and plus sign
            let cleanPhone = phoneNumber.replace(/[\s\-\+]/g, '');


            const encodedMessage = encodeURIComponent(message);
            const whatsappUrl = `https://wa.me/${cleanPhone}?text=${encodedMessage}`;
            window.open(whatsappUrl, '_blank');
        }

        // Grid row button handlers (scoped)
        document.querySelectorAll('.send-whatsapp').forEach(button => {
            button.addEventListener('click', function () {
                const message = this.getAttribute('data-message') || '';
                const phone = (this.getAttribute('data-phone') || '').trim();

                if (!phone) {
                    alert('Phone number not found.');
                    return;
                }

                const cleanPhone = phone.replace(/\D/g, '');
                const encodedMessage = encodeURIComponent(message);
                const whatsappUrl = `https://wa.me/${cleanPhone}?text=${encodedMessage}`;
                window.open(whatsappUrl, '_blank');
            });
        });
    </script>
}