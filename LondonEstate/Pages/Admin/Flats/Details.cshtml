@section Scripts {
    <script>
        function fallbackCopy(value) {
            const textarea = document.createElement('textarea');
            textarea.value = value;
            textarea.style.position = 'fixed';
            textarea.style.left = '-9999px';
            document.body.appendChild(textarea);
            textarea.select();
            try { document.execCommand('copy'); } catch { /* ignore */ }
            document.body.removeChild(textarea);
        }

        function copyElementText(elementId, label) {
            const el = document.getElementById(elementId);
            const text = el ? el.textContent.trim() : '';
            if (!text) return;
            const payload = label ? `${label}:\n${text}` : text;
            if (navigator.clipboard && navigator.clipboard.writeText) {
                navigator.clipboard.writeText(payload).catch(() => fallbackCopy(payload));
            } else {
                fallbackCopy(payload);
            }
        }

        function copyWifi() {
            const wifiEl = document.getElementById('wifi');
            
            const wifi = wifiEl ? wifiEl.textContent : '';
            if (!wifi) return;
            if (navigator.clipboard && navigator.clipboard.writeText) {
                navigator.clipboard.writeText(wifi).catch(() => fallbackCopy(wifi));
            } else {
                fallbackCopy(wifi);
            }
        }
    </script>
}