@page
@model LondonEstate.Pages.Admin.Flats.EditModel

@{
    ViewData["Title"] = "Edit";
}

<div class="row">
    <div class="col-md-4">
        <form method="post" enctype="multipart/form-data">
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>
            <input type="hidden" asp-for="Flat.Id" />
            <div class="form-group">
                <label asp-for="Flat.Name" class="control-label"></label>
                <input asp-for="Flat.Name" class="form-control" />
                <span asp-validation-for="Flat.Name" class="text-danger"></span>
            </div>
            <div class="form-group">
                <label asp-for="Flat.OnlineName" class="control-label"></label>
                <input asp-for="Flat.OnlineName" class="form-control" />
                <span asp-validation-for="Flat.OnlineName" class="text-danger"></span>
            </div>
            <div class="form-group">
                <label asp-for="Flat.Address" class="control-label"></label>
                <input asp-for="Flat.Address" class="form-control" />
                <span asp-validation-for="Flat.Address" class="text-danger"></span>
            </div>
            <div class="form-group">
                <label asp-for="Flat.FlatUrl" class="control-label"></label>
                <input asp-for="Flat.FlatUrl" class="form-control" />
                <span asp-validation-for="Flat.FlatUrl" class="text-danger"></span>
            </div>
            @* <div class="form-group">
                <label asp-for="Flat.CheckIn" class="control-label"></label>
                <input type="date" asp-for="Flat.CheckIn" class="form-control" />
                <span asp-validation-for="Flat.CheckIn" class="text-danger"></span>
            </div>
            <div class="form-group">
                <label asp-for="Flat.CheckOut" class="control-label"></label>
                <input type="date" asp-for="Flat.CheckOut" class="form-control" />
                <span asp-validation-for="Flat.CheckOut" class="text-danger"></span>
            </div> *@
         
            <div class="form-group">
                <label asp-for="Flat.Wifi" class="control-label"></label>
                <textarea asp-for="Flat.Wifi" class="form-control" rows="5"></textarea>
                <span asp-validation-for="Flat.Wifi" class="text-danger"></span>
            </div>
            <div class="form-group">
                <label asp-for="Flat.CheckinInstruction" class="control-label"></label>
                <textarea asp-for="Flat.CheckinInstruction" class="form-control" rows="5"></textarea>
                <span asp-validation-for="Flat.CheckinInstruction" class="text-danger"></span>
            </div>
          @*   <div class="form-group">
                <label asp-for="Flat.VisualGuideUrl" class="control-label"></label>
                <input asp-for="Flat.VisualGuideUrl" class="form-control" />
                <span asp-validation-for="Flat.VisualGuideUrl" class="text-danger"></span>
            </div> *@
         
          @*   <div class="form-group form-check">
                <label class="form-check-label">
                    <input class="form-check-input" asp-for="Flat.Empty" /> @Html.DisplayNameFor(model => model.Flat.Empty)
                </label>
            </div> *@

            <div class="form-group">
                <label for="ImageUpload" class="control-label">Upload Image</label>
                <input type="file" id="ImageUpload" name="imageUpload" class="form-control" accept=".jpg,.jpeg,.png,.gif" />
                <small class="form-text text-muted">Allowed formats: JPG, JPEG, PNG, GIF (Max 7 MB)</small>
                <span id="imageError" class="text-danger"></span>
            </div>

            @if (!string.IsNullOrEmpty(Model.Flat.Image))
            {
                <div class="form-group">
                    <label class="control-label">Current Image</label>
                    <div class="mt-2">
                        <img src="@Model.Flat.Image" alt="@Model.Flat.Name" style="max-width: 100%; max-height: 200px; border-radius: 5px;" />
                    </div>
                </div>
            }

            <div class="form-group">
                <input type="submit" value="Update" class="btn btn-primary my-3" />
            </div>
        </form>
    </div>
</div>

<div>
    <a asp-page="./Index">Back to List</a>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
    <script>
        document.getElementById('ImageUpload').addEventListener('change', function() {
            const file = this.files[0];
            const errorSpan = document.getElementById('imageError');
            errorSpan.textContent = '';

            if (!file) return;

            const maxSize = 7 * 1024 * 1024; // 7 MB
            const allowedExtensions = ['.jpg', '.jpeg', '.png', '.gif'];
            const fileName = file.name.toLowerCase();
            const fileExtension = fileName.substring(fileName.lastIndexOf('.'));

            if (file.size > maxSize) {
                errorSpan.textContent = 'File size exceeds 7 MB limit.';
                this.value = '';
            } else if (!allowedExtensions.includes(fileExtension)) {
                errorSpan.textContent = 'Only JPG, JPEG, PNG, and GIF files are allowed.';
                this.value = '';
            }
        });
    </script>
}
