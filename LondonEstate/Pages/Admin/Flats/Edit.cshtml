@page
@model LondonEstate.Pages.Admin.Flats.EditModel

@{
    ViewData["Title"] = "Edit";
}

<h1>Edit</h1>

<h4>Flat</h4>
<hr />
<div class="row">
    <div class="col-md-4">
        <form method="post">
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>
            <input type="hidden" asp-for="Flat.Id" />
            <div class="form-group">
                <label asp-for="Flat.Name" class="control-label"></label>
                <input asp-for="Flat.Name" class="form-control" />
                <span asp-validation-for="Flat.Name" class="text-danger"></span>
            </div>
            <div class="form-group">
                <label asp-for="Flat.CheckIn" class="control-label"></label>
                <input type="date" asp-for="Flat.CheckIn" class="form-control" />
                <span asp-validation-for="Flat.CheckIn" class="text-danger"></span>
            </div>
            <div class="form-group">
                <label asp-for="Flat.CheckOut" class="control-label"></label>
                <input type="date" asp-for="Flat.CheckOut" class="form-control" />
                <span asp-validation-for="Flat.CheckOut" class="text-danger"></span>
            </div>
            <div class="form-group form-check">
                <label class="form-check-label">
                    <input class="form-check-input" asp-for="Flat.Empty" /> @Html.DisplayNameFor(model => model.Flat.Empty)
                </label>
            </div>
            <div class="form-group">
                <label asp-for="Flat.SSID" class="control-label"></label>
                <input asp-for="Flat.SSID" class="form-control" />
                <span asp-validation-for="Flat.SSID" class="text-danger"></span>
            </div>
            <div class="form-group">
                <label asp-for="Flat.Password" class="control-label"></label>
                <input asp-for="Flat.Password" class="form-control" />
                <span asp-validation-for="Flat.Password" class="text-danger"></span>
            </div>
            <div class="form-group">
                <label asp-for="Flat.CheckinInstruction" class="control-label"></label>
                <input asp-for="Flat.CheckinInstruction" class="form-control" />
                <span asp-validation-for="Flat.CheckinInstruction" class="text-danger"></span>
            </div>
            <div class="form-group">
                <label asp-for="Flat.VisualGuideUrl" class="control-label"></label>
                <input asp-for="Flat.VisualGuideUrl" class="form-control" />
                <span asp-validation-for="Flat.VisualGuideUrl" class="text-danger"></span>
            </div>
            <div class="form-group">
                <label asp-for="Flat.Address" class="control-label"></label>
                <input asp-for="Flat.Address" class="form-control" />
                <span asp-validation-for="Flat.Address" class="text-danger"></span>
            </div>
            <div class="form-group">
                <label asp-for="Flat.Url" class="control-label"></label>
                <input asp-for="Flat.Url" class="form-control" />
                <span asp-validation-for="Flat.Url" class="text-danger"></span>
            </div>
            <div class="form-group">
                <input type="submit" value="Save" class="btn btn-primary" />
            </div>
        </form>
    </div>
</div>

<div>
    <a asp-page="./Index">Back to List</a>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
