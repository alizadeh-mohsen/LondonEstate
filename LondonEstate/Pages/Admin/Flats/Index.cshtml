@page
@model LondonEstate.Pages.Admin.Flats.IndexModel

@{
    ViewData["Title"] = "Index";
}

<div class="mb-4">
    <div class="row g-3 mb-3">
        <div class="col-md-8">
            <input type="text" class="form-control" id="searchInput" placeholder="Search by property name or online name..." />
        </div>
        <div class="col-md-4">
            <button class="btn btn-secondary w-100" id="clearSearch" type="button">
                <i class="bi bi-x-circle me-2"></i>Clear
            </button>
        </div>
    </div>
</div>

<p>
    <a class="btn btn-primary" asp-page="Create">Create New</a>
</p>
<div class="table-responsive">
    <table class="table table-sm" id="flatsTable">

    <thead>
        <tr>
            <th>
                    Property (@Model.Flat.Count)
            </th>

            @* <th>
               Address
            </th> *@
            <th></th>
        </tr>
    </thead>
    <tbody>
        @foreach (var item in Model.Flat)
        {
            <tr class="flat-row" data-name="@item.Name?.ToLower()" data-online-name="@item.OnlineName?.ToLower()">
                <td>
                   <a  href="@Html.DisplayFor(modelItem => item.FlatUrl)" target="_blank">
                        @Html.DisplayFor(modelItem => item.OnlineName)
                    </a>
                        <div class="@(item.Open ? "" : "text-danger")">
                            @Html.DisplayFor(modelItem => item.Name)
                        </div>
                </td>

                @* <td>
                     @Html.DisplayFor(modelItem => item.Address)
                </td> *@

                <td>
                         <a class="btn btn-sm btn-primary m-1 " asp-page="./Details" asp-route-id="@item.Id">Details</a>
                        <a class="btn btn-sm btn-primary m-1" asp-page="./Edit" asp-route-id="@item.Id">Edit</a>
                        <a class="btn btn-sm btn-primary m-1" asp-page="./Delete" asp-route-id="@item.Id">Delete</a>
                </td>
            </tr>
        }
    </tbody>
</table>
</div>

<script>
    // SEARCH FUNCTIONALITY
    const searchInput = document.getElementById("searchInput");
    const clearSearchBtn = document.getElementById("clearSearch");
    const flatRows = document.querySelectorAll("#flatsTable tbody tr.flat-row");

    function filterTable() {
        const searchTerm = searchInput.value.toLowerCase().trim();

        flatRows.forEach(row => {
            const name = row.getAttribute("data-name") || "";
            const onlineName = row.getAttribute("data-online-name") || "";

            const matches = name.includes(searchTerm) || onlineName.includes(searchTerm) || searchTerm === "";

            row.style.display = matches ? "" : "none";
        });
    }

    searchInput.addEventListener("input", filterTable);

    clearSearchBtn.addEventListener("click", () => {
        searchInput.value = "";
        filterTable();
    });
</script>
