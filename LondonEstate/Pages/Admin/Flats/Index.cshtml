@page
@model LondonEstate.Pages.Admin.Flats.IndexModel

@{
    ViewData["Title"] = "Index";
}

<h1>Index</h1>

<p>
    <a asp-page="Create">Create New</a>
</p>
<table class="table">
    <thead>
        <tr>
            <th>
                @Html.DisplayNameFor(model => model.Flat[0].Name)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.Flat[0].CheckIn)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.Flat[0].CheckOut)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.Flat[0].Empty)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.Flat[0].SSID)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.Flat[0].Password)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.Flat[0].CheckinInstruction)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.Flat[0].VisualGuideUrl)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.Flat[0].Address)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.Flat[0].Url)
            </th>
            <th></th>
        </tr>
    </thead>
    <tbody>
@foreach (var item in Model.Flat) {
        <tr>
            <td>
                @Html.DisplayFor(modelItem => item.Name)
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.CheckIn)
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.CheckOut)
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.Empty)
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.SSID)
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.Password)
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.CheckinInstruction)
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.VisualGuideUrl)
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.Address)
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.Url)
            </td>
            <td>
                <a asp-page="./Edit" asp-route-id="@item.Id">Edit</a> |
                <a asp-page="./Details" asp-route-id="@item.Id">Details</a> |
                <a asp-page="./Delete" asp-route-id="@item.Id">Delete</a>
            </td>
        </tr>
}
    </tbody>
</table>
