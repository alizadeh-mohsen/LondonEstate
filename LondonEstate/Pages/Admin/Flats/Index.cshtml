@page
@model LondonEstate.Pages.Admin.Flats.IndexModel

@{
    ViewData["Title"] = "Index";
}


<p>
    <a class="btn btn-primary" asp-page="Create">Create New</a>
</p>
<table class="table">
    <thead>
        <tr>
            <th>
                @Html.DisplayNameFor(model => model.Flat[0].Name)
            </th>

            <th>
                @Html.DisplayNameFor(model => model.Flat[0].Address)
            </th>
            <th></th>
        </tr>
    </thead>
    <tbody>
        @foreach (var item in Model.Flat)
        {
            <tr>
                <td>
                    <a href="@Html.DisplayFor(modelItem => item.FlatUrl)" target="_blank">
                        @Html.DisplayFor(modelItem => item.Name)
                    </a>
                </td>

                <td>
                    @Html.DisplayFor(modelItem => item.Address)
                </td>

                <td>
                    <a asp-page="./Edit" asp-route-id="@item.Id">Edit</a> |
                    <a asp-page="./Details" asp-route-id="@item.Id">Details</a> |
                    <a asp-page="./Delete" asp-route-id="@item.Id">Delete</a>
                </td>
            </tr>
        }
    </tbody>
</table>
