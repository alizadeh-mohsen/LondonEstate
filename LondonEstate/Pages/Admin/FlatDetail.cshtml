@page
@model LondonEstate.Pages.Admin.FlatDetailModel

@{
    ViewData["Title"] = "Details";
}

<h1> @Html.DisplayFor(model => model.Flat.Name)</h1>
<hr />

<div>
    <dl class="row">
     
        <dt class="col-sm-2">
            WIFI   
        </dt>
        <dd class="col-sm-10 d-flex align-items-center">
            <div class="me-3">
                <div>Wi‑Fi Name:<span id="wifi-ssid">@Html.Encode(Model.Flat?.SSID)</span></div>
                <div>Password:<span id="wifi-password">@Html.Encode(Model.Flat?.Password)</span></div>
            </div>
            <button type="button" class="btn btn-sm btn-primary" onclick="copyWifi()" aria-label="Copy Wi-Fi credentials">
                Copy
            </button>
        </dd>
        <dt class="col-sm-2">
            @Html.DisplayNameFor(model => model.Flat.CheckinInstruction)
        </dt>
        <dd class="col-sm-10 d-flex align-items-start">
            <div id="checkin-instruction" class="flex-grow-1">
              <textarea class="form-control" readonly>@Html.DisplayFor(model => model.Flat.CheckinInstruction)</textarea>
            </div>
            <button type="button" class="btn btn-sm btn-primary ms-3" onclick="copyElementText('checkin-instruction','Check‑in instruction')" aria-label="Copy check-in instruction">
                Copy
            </button>
        </dd>
        
    </dl>
</div>
<div>
    <a asp-page="./Properties">Back to List</a>
</div>

@section Scripts {
    <script>
        function fallbackCopy(value) {
            const textarea = document.createElement('textarea');
            textarea.value = value;
            textarea.style.position = 'fixed';
            textarea.style.left = '-9999px';
            document.body.appendChild(textarea);
            textarea.select();
            try { document.execCommand('copy'); } catch { /* ignore */ }
            document.body.removeChild(textarea);
        }

        function copyElementText(elementId, label) {
            const el = document.getElementById(elementId);
            const text = el ? el.textContent.trim() : '';
            if (!text) return;
            const payload = label ? `${label}:\n${text}` : text;
            if (navigator.clipboard && navigator.clipboard.writeText) {
                navigator.clipboard.writeText(payload).catch(() => fallbackCopy(payload));
            } else {
                fallbackCopy(payload);
            }
        }

        function copyWifi() {
            const ssidEl = document.getElementById('wifi-ssid');
            const pwdEl = document.getElementById('wifi-password');
            const ssid = ssidEl ? ssidEl.textContent.trim() : '';
            const pwd = pwdEl ? pwdEl.textContent.trim() : '';
            const text = `Wi‑Fi Name: ${ssid}\nPassword: ${pwd}`;
            if (navigator.clipboard && navigator.clipboard.writeText) {
                navigator.clipboard.writeText(text).catch(() => fallbackCopy(text));
            } else {
                fallbackCopy(text);
            }
        }
    </script>
}