@page
@using LondonEstate.Utils.Extensions
@model LondonEstate.Pages.Admin.BookingsModel
@{
}

@{
    ViewData["Title"] = "Properties";
    var cutoff = DateTime.Today.AddHours(11);
}

<div class="mb-4">
    

    @if (!string.IsNullOrEmpty(Model.SuccessMessage))
    {
        <div class="alert alert-success alert-dismissible fade show" role="alert">
            <i class="bi bi-check-circle me-2"></i>
            @Model.SuccessMessage
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }

    @if (!string.IsNullOrEmpty(Model.ErrorMessage))
    {
        <div class="alert alert-danger alert-dismissible fade show" role="alert">
            <i class="bi bi-exclamation-circle me-2"></i>
            @Model.ErrorMessage
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }

    <div class="card mb-4">
        <div class="card-body">
            <form method="post" asp-page-handler="Upload" enctype="multipart/form-data">
                <div class="row g-3">
                    <div class="col-md-8">
                        <div class="input-group">
                            <input type="file" class="form-control" id="excelFile" name="excelFile" accept=".xlsx,.xls" required />
                            <button class="btn btn-primary" type="submit">
                                <i class="bi bi-cloud-upload me-2"></i>Import Bookings
                            </button>
                        </div>
                    </div>
                </div>
            </form>
        </div>
    </div>
</div>

<div class="table-responsive">
    <table class="table table-sm">
    <thead>
        <tr>
            <th>
                Property
            </th>
            @*  <th>
                @Html.DisplayNameFor(model => model.Flat[0].Address)
            </th> *@
            <th class="text-center">
               Arrival / Departure
            </th>
            <th class="text-center">
                Booker name
            </th>
        </tr>
    </thead>
    <tbody>
        @foreach (var item in Model.Flat)
        {
            // safe evaluation for nullable CheckOut
            var isAfterCutoff = item.CheckOut is DateTime co && co > cutoff;

            <tr>
                <td>
                    <a asp-page="./Checkin" asp-route-id="@item.Id">
                        @Html.DisplayFor(modelItem => item.Name)
                    </a>
                       @*  <div>
                            @Html.DisplayFor(modelItem => item.Name)
                        </div> *@
                </td>
                @*  <td>
                    @Html.DisplayFor(modelItem => item.Address)
                </td> *@
                <td class="@(isAfterCutoff ? "bg-danger text-white" : "bg-success text-white")" >
                    @item.CheckIn?.ToUkDateString() - @item.CheckOut?.ToUkDateString()
                </td>
                <td  >
                    <a target="_blank" href="@(Model.Flat?.ElementAtOrDefault(0)?.ReservationUrl ?? "#")">
                        @Html.DisplayFor(modelItem => item.GuestName)
                    </a>
                </td>
               
            </tr>
        }
    </tbody>
</table>
</div>