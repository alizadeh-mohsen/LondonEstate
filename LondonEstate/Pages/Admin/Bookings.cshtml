@page
@using LondonEstate.Utils.Extensions
@model LondonEstate.Pages.Admin.BookingsModel

@{
    ViewData["Title"] = "Bookings";
    var cutoff = DateTime.Today.AddHours(11);
}

<div class="mb-4">

    @if (!string.IsNullOrEmpty(Model.SuccessMessage))
    {
        <div class="alert alert-success alert-dismissible fade show" role="alert">
            <i class="bi bi-check-circle me-2"></i>
            @Model.SuccessMessage
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    @if (!string.IsNullOrEmpty(Model.ErrorMessage))
    {
        <div class="alert alert-danger alert-dismissible fade show" role="alert">
            <i class="bi bi-exclamation-circle me-2"></i>
            @Model.ErrorMessage
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    <div class="card mb-4">
        <div class="card-body">
            <form method="post" asp-page-handler="Upload" enctype="multipart/form-data">
                <div class="row g-3">
                    <div class="col-md-8">
                        <div class="input-group">
                            <input type="file" class="form-control" id="excelFile" name="excelFile" accept=".xlsx,.xls" required />
                            <button class="btn btn-primary" type="submit">
                                <i class="bi bi-cloud-upload me-2"></i>Import Bookings
                            </button>
                        </div>
                    </div>
                </div>
            </form>
        </div>
    </div>
</div>

<!-- TABLE -->
<div class="mx-2">
    <ul>
        @foreach (var item in Model.EmptyFlats)
        {
            <li>
                @item.Name
            </li>
        }
    </ul>
</div>


<!-- TABLE -->
<div class="table-responsive" style="max-height: 75vh; overflow-y: auto;">
    <table class="table table-sm align-middle" id="bookingTable">
        <thead class="table-light sticky-top">
            <tr>
                <th data-sort="string">Property (@Model.Flat.Count)</th>
                <th data-sort="date">Dates</th>
                <th data-sort="string">Guest</th>
            </tr>
        </thead>

        <tbody>
            @foreach (var item in Model.Flat)
            {
                var today = DateTime.Today;
                var checkIn = item.CheckIn?.Date;
                var checkOut = item.CheckOut?.Date;

                var isAfterCutoff = item.CheckOut is DateTime co && co > cutoff;
                var status = checkOut == today.AddDays(1) ? "tomorrow" : "";
                var badge = !string.IsNullOrEmpty(status) ? $"<span class='badge bg-danger text-white'>{status}</span>" : "";

                <tr>

                    <!-- PROPERTY -->
                    <td class="@(isAfterCutoff ? "bg-secondary" : "bg-white text-white")">
                        <a asp-page="./Checkin" asp-route-id="@item.Id"
                           class="fw-semibold text-decoration-none text-dark">
                            @item.Name
                        </a>
                        <div class="text-muted small">@item.OnlineName</div>
                    </td>

                    <!-- DATES -->
                    <td class="@(isAfterCutoff ? "bg-secondary" : "bg-white text-white")">
                        <div class="fw-semibold">
                            @item.CheckIn?.ToUkDateString() - @item.CheckOut?.ToUkDateString()
                        </div>


                    </td>

                    <!-- GUEST -->
                    <td class="@(isAfterCutoff ? "bg-secondary" : "bg-white text-white")">
                        <div class="small">@item.GuestName</div>
                        <div class="mt-1">
                            @Html.Raw(badge)
                        </div>
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>


<!-- SORTING SCRIPT -->
<script>
    document.querySelectorAll("#bookingTable th[data-sort]").forEach(th => {
        th.style.cursor = "pointer";
        th.addEventListener("click", () => {
            const table = th.closest("table");
            const tbody = table.querySelector("tbody");
            const rows = Array.from(tbody.querySelectorAll("tr"));
            const index = Array.from(th.parentNode.children).indexOf(th);
            const type = th.dataset.sort;
            const asc = !th.classList.contains("sorted-asc");

            rows.sort((a, b) => {
                let A = a.children[index].innerText.trim();
                let B = b.children[index].innerText.trim();

                if (type === "date") {
                    A = Date.parse(A.replace(/–/g, "-")) || 0;
                    B = Date.parse(B.replace(/–/g, "-")) || 0;
                }

                return asc ? A.localeCompare(B) : B.localeCompare(A);
            });

            tbody.innerHTML = "";
            rows.forEach(r => tbody.appendChild(r));

            table.querySelectorAll("th").forEach(x => x.classList.remove("sorted-asc", "sorted-desc"));
            th.classList.add(asc ? "sorted-asc" : "sorted-desc");
        });
    });
</script>
